{% doc %}
  @prompt
    Create a quantity bundle selector UI for a product page. It should display pack size options as styled card buttons (e.g., Singles, 3-Pack, 6-Pack). Each card shows the pack name, a savings amount (e.g., "Save £47"), and optionally a "Best Deal" badge on the recommended option. The selected card has a bold border to indicate active selection. Clicking a card updates the selected variant and the add-to-cart button. The savings and badge text should be configurable via block settings. The design should be clean and modern, matching a typical Shopify product page layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bundle-selector-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-bundle-selector__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 16px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-bundle-selector__cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
  }

  .ai-bundle-selector__card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.card_bg_color }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 16px 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 100px;
  }

  .ai-bundle-selector__card-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.card_hover_border_color }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-bundle-selector__card-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.card_active_border_color }};
    border-width: {{ block.settings.card_active_border_width }}px;
    background-color: {{ block.settings.card_active_bg_color }};
  }

  .ai-bundle-selector__badge-{{ ai_gen_id }} {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-bundle-selector__pack-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.pack_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.pack_name_color }};
    margin: 0;
  }

  .ai-bundle-selector__card-{{ ai_gen_id }}.active .ai-bundle-selector__pack-name-{{ ai_gen_id }} {
    color: {{ block.settings.pack_name_active_color }};
  }

  .ai-bundle-selector__savings-{{ ai_gen_id }} {
    font-size: {{ block.settings.savings_size }}px;
    font-weight: 500;
    color: {{ block.settings.savings_color }};
    margin: 0;
  }

  .ai-bundle-selector__card-{{ ai_gen_id }}.active .ai-bundle-selector__savings-{{ ai_gen_id }} {
    color: {{ block.settings.savings_active_color }};
  }

  .ai-bundle-selector__price-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-bundle-selector__card-{{ ai_gen_id }}.active .ai-bundle-selector__price-{{ ai_gen_id }} {
    color: {{ block.settings.price_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-bundle-selector__cards-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    }

    .ai-bundle-selector__card-{{ ai_gen_id }} {
      padding: 12px 8px;
      min-height: 90px;
    }
  }
{% endstyle %}

<bundle-selector-{{ ai_gen_id }}
  class="ai-bundle-selector-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-product-id="{{ product.id }}"
>
  {% if block.settings.heading != blank %}
    <h3 class="ai-bundle-selector__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  <div class="ai-bundle-selector__cards-{{ ai_gen_id }}">
    {% if block.settings.option_1_enabled %}
      <div
        class="ai-bundle-selector__card-{{ ai_gen_id }} {% if block.settings.option_1_default %}active{% endif %}"
        data-variant-id="{{ block.settings.option_1_variant.id }}"
        data-variant-available="{{ block.settings.option_1_variant.available }}"
        role="button"
        tabindex="0"
        aria-pressed="{% if block.settings.option_1_default %}true{% else %}false{% endif %}"
      >
        {% if block.settings.option_1_show_badge and block.settings.option_1_badge_text != blank %}
          <span class="ai-bundle-selector__badge-{{ ai_gen_id }}">{{ block.settings.option_1_badge_text }}</span>
        {% endif %}
        <p class="ai-bundle-selector__pack-name-{{ ai_gen_id }}">{{ block.settings.option_1_name }}</p>
        {% if block.settings.option_1_savings != blank %}
          <p class="ai-bundle-selector__savings-{{ ai_gen_id }}">{{ block.settings.option_1_savings }}</p>
        {% endif %}
        {% if block.settings.option_1_variant %}
          <p class="ai-bundle-selector__price-{{ ai_gen_id }}">{{ block.settings.option_1_variant.price | money }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.option_2_enabled %}
      <div
        class="ai-bundle-selector__card-{{ ai_gen_id }} {% if block.settings.option_2_default %}active{% endif %}"
        data-variant-id="{{ block.settings.option_2_variant.id }}"
        data-variant-available="{{ block.settings.option_2_variant.available }}"
        role="button"
        tabindex="0"
        aria-pressed="{% if block.settings.option_2_default %}true{% else %}false{% endif %}"
      >
        {% if block.settings.option_2_show_badge and block.settings.option_2_badge_text != blank %}
          <span class="ai-bundle-selector__badge-{{ ai_gen_id }}">{{ block.settings.option_2_badge_text }}</span>
        {% endif %}
        <p class="ai-bundle-selector__pack-name-{{ ai_gen_id }}">{{ block.settings.option_2_name }}</p>
        {% if block.settings.option_2_savings != blank %}
          <p class="ai-bundle-selector__savings-{{ ai_gen_id }}">{{ block.settings.option_2_savings }}</p>
        {% endif %}
        {% if block.settings.option_2_variant %}
          <p class="ai-bundle-selector__price-{{ ai_gen_id }}">{{ block.settings.option_2_variant.price | money }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.option_3_enabled %}
      <div
        class="ai-bundle-selector__card-{{ ai_gen_id }} {% if block.settings.option_3_default %}active{% endif %}"
        data-variant-id="{{ block.settings.option_3_variant.id }}"
        data-variant-available="{{ block.settings.option_3_variant.available }}"
        role="button"
        tabindex="0"
        aria-pressed="{% if block.settings.option_3_default %}true{% else %}false{% endif %}"
      >
        {% if block.settings.option_3_show_badge and block.settings.option_3_badge_text != blank %}
          <span class="ai-bundle-selector__badge-{{ ai_gen_id }}">{{ block.settings.option_3_badge_text }}</span>
        {% endif %}
        <p class="ai-bundle-selector__pack-name-{{ ai_gen_id }}">{{ block.settings.option_3_name }}</p>
        {% if block.settings.option_3_savings != blank %}
          <p class="ai-bundle-selector__savings-{{ ai_gen_id }}">{{ block.settings.option_3_savings }}</p>
        {% endif %}
        {% if block.settings.option_3_variant %}
          <p class="ai-bundle-selector__price-{{ ai_gen_id }}">{{ block.settings.option_3_variant.price | money }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.option_4_enabled %}
      <div
        class="ai-bundle-selector__card-{{ ai_gen_id }} {% if block.settings.option_4_default %}active{% endif %}"
        data-variant-id="{{ block.settings.option_4_variant.id }}"
        data-variant-available="{{ block.settings.option_4_variant.available }}"
        role="button"
        tabindex="0"
        aria-pressed="{% if block.settings.option_4_default %}true{% else %}false{% endif %}"
      >
        {% if block.settings.option_4_show_badge and block.settings.option_4_badge_text != blank %}
          <span class="ai-bundle-selector__badge-{{ ai_gen_id }}">{{ block.settings.option_4_badge_text }}</span>
        {% endif %}
        <p class="ai-bundle-selector__pack-name-{{ ai_gen_id }}">{{ block.settings.option_4_name }}</p>
        {% if block.settings.option_4_savings != blank %}
          <p class="ai-bundle-selector__savings-{{ ai_gen_id }}">{{ block.settings.option_4_savings }}</p>
        {% endif %}
        {% if block.settings.option_4_variant %}
          <p class="ai-bundle-selector__price-{{ ai_gen_id }}">{{ block.settings.option_4_variant.price | money }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</bundle-selector-{{ ai_gen_id }}>

<script>
  (function() {
    class BundleSelector{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.cards = [];
        this.productForm = null;
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-bundle-selector__card-{{ ai_gen_id }}');
        this.productForm = document.querySelector('form[action*="/cart/add"]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', () => this.handleCardClick(card));
          card.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              this.handleCardClick(card);
            }
          });
        });
      }

      handleCardClick(selectedCard) {
        const variantId = selectedCard.dataset.variantId;
        const isAvailable = selectedCard.dataset.variantAvailable === 'true';

        if (!variantId || !isAvailable) {
          return;
        }

        this.cards.forEach((card) => {
          card.classList.remove('active');
          card.setAttribute('aria-pressed', 'false');
        });

        selectedCard.classList.add('active');
        selectedCard.setAttribute('aria-pressed', 'true');

        this.updateProductForm(variantId);
        this.updateURL(variantId);
      }

      updateProductForm(variantId) {
        if (!this.productForm) {
          return;
        }

        const variantInput = this.productForm.querySelector('input[name="id"]');
        if (variantInput) {
          variantInput.value = variantId;
          variantInput.dispatchEvent(new Event('change', { bubbles: true }));
        }

        const selectElement = this.productForm.querySelector('select[name="id"]');
        if (selectElement) {
          selectElement.value = variantId;
          selectElement.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      updateURL(variantId) {
        const url = new URL(window.location.href);
        url.searchParams.set('variant', variantId);
        window.history.replaceState({}, '', url);
      }
    }

    customElements.define('bundle-selector-{{ ai_gen_id }}', BundleSelector{{ ai_gen_id }});
  })();
</script>

